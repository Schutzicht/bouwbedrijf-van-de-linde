---
interface Props {
  index?: string;
  label: string;
  title: string;
  align?: "left" | "center";
  tone?: "light" | "dark";
}
const { label, title, align = "left" } = Astro.props;
---

<div class={`reveal ${align === "center" ? "mx-auto max-w-2xl text-center" : ""}`}>
  <p class={`eyebrow ${align === "center" ? "eyebrow-center" : ""}`}>{label}</p>
  <h2 class="display h-section mt-5" set:html={title}></h2>
  <slot />
</div>
