---
import { hero, company, stats } from "../data/site";
const heroStats = stats.slice(0, 3);
---

<section id="top" class="ctx-light relative overflow-hidden border-b border-[var(--border)]" style="background:var(--color-kalk);">
  <div class="container-edge grid gap-12 pt-28 pb-16 sm:pt-32 lg:grid-cols-12 lg:gap-12 lg:pt-36 lg:pb-24">
    <div class="lg:col-span-7 lg:self-center">
      <p class="eyebrow reveal">{company.tagline} · Goes</p>

      <h1 class="display reveal mt-5 text-[var(--color-navy-ink)]" style="font-size:clamp(2rem,5.2vw,4.2rem);line-height:1.07;">
        Bouwen met <span class="mark-geel">karakter</span>,<br />voor generaties.
      </h1>

      <p class="reveal mt-7 max-w-xl text-[var(--fg-soft)]" style="font-size:1.075rem;line-height:1.7;">
        {hero.intro}
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center gap-3">
        <a href="/contact" class="btn btn-navy">Offerte aanvragen</a>
        <a href="/projecten" class="btn btn-ghost link-sweep">Bekijk projecten</a>
      </div>

      <dl class="reveal mt-12 grid max-w-lg grid-cols-3 gap-6 border-t border-[var(--line)] pt-8">
        {
          heroStats.map((s) => (
            <div>
              <dd class="display text-[var(--color-navy)]" style="font-size:clamp(1.9rem,3.5vw,2.6rem);font-weight:600;line-height:1;">
                <span class="tnum" data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</span>
              </dd>
              <dt class="mt-2 text-xs leading-snug text-[var(--fg-muted)]">{s.label}</dt>
            </div>
          ))
        }
      </dl>
    </div>

    <!-- Beeldcollage -->
    <div class="reveal relative lg:col-span-5">
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        <div class="col-span-2 overflow-hidden rounded-2xl">
          <img src="/img/hero.jpg" alt="Door Van de Linde gerealiseerd project in het Zeeuwse landschap" class="h-64 w-full object-cover sm:h-80 lg:h-[24rem]" width="1200" height="700" fetchpriority="high" />
        </div>
        <div class="overflow-hidden rounded-2xl">
          <img src="/projecten/p-geerteskerk.jpg" alt="Restauratie van de Geerteskerk in Kloetinge" class="h-36 w-full object-cover sm:h-48" loading="lazy" width="600" height="450" />
        </div>
        <div class="overflow-hidden rounded-2xl">
          <img src="/projecten/p-trintellaan.jpg" alt="Nieuwbouwvilla in Kortgene" class="h-36 w-full object-cover sm:h-48" loading="lazy" width="600" height="450" />
        </div>
      </div>

      <div class="mt-4 flex items-center gap-3.5 rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-4 shadow-[var(--shadow-soft)]">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl" style="background:rgba(251,204,26,0.18);">
          <svg width="22" height="18" viewBox="0 0 24 20" fill="none" stroke="var(--color-navy)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9 12 2l10 7"/><path d="M5 7v11h14V7" opacity="0.55"/></svg>
        </span>
        <div class="text-sm">
          <p class="font-semibold text-[var(--fg)]">Drie generaties vakmanschap</p>
          <p class="text-[var(--fg-muted)]">Van rijksmonument tot nieuwbouwvilla</p>
        </div>
        <a href={company.phoneHref} class="link-sweep ml-auto hidden shrink-0 text-sm font-semibold text-[var(--color-navy)] sm:block">Bel ons</a>
      </div>
    </div>
  </div>
</section>
