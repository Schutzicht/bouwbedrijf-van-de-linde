---
import { projecten } from "../data/site";
import SectionHead from "./SectionHead.astro";
const teaser = projecten.slice(0, 3);
---

<section class="ctx-light relative py-24 sm:py-32">
  <div class="container-edge">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHead index="03" label="Gerealiseerd werk" title="Een greep uit<br />ons werk." />
      <a href="/projecten" class="link-sweep reveal hidden shrink-0 items-center gap-2 text-sm font-semibold text-[var(--color-navy)] lg:inline-flex">
        Bekijk alle projecten
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="mt-12 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        teaser.map((p) => (
          <a href="/projecten" class="proj-card group reveal block">
            <div class="plate relative" style="aspect-ratio:4/3;">
              <img src={p.image} alt={`${p.title}, ${p.place}`} class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.05]" loading="lazy" width="800" height="600" />
            </div>
            <div class="mt-4 flex items-baseline justify-between gap-4 border-t border-[var(--line)] pt-3.5">
              <span class="label label-accent">{p.category}</span>
              <span class="label">{p.place}</span>
            </div>
            <h3 class="proj-title mt-2 inline serif text-[1.3rem] font-medium leading-tight">{p.title}</h3>
          </a>
        ))
      }
    </div>

    <a href="/projecten" class="btn btn-ghost reveal mt-10 inline-flex lg:hidden">Bekijk alle projecten</a>
  </div>
</section>

<style>
  .proj-title { background-image: linear-gradient(var(--color-geel), var(--color-geel)); background-repeat: no-repeat; background-position: 0 100%; background-size: 0 2px; transition: background-size 0.5s var(--ease-out-soft); padding-bottom: 2px; }
  .proj-card:hover .proj-title { background-size: 100% 2px; }
</style>
