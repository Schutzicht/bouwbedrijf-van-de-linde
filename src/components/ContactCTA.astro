---
import { company } from "../data/site";
---

<section class="ctx-dark relative overflow-hidden py-20 sm:py-28" style="background:var(--color-navy-deep);">
  <div class="wash wash-geel" style="width:440px;height:440px;top:-160px;right:-120px;opacity:0.14;"></div>
  <div class="container-edge relative">
    <div class="flex flex-col items-start gap-8 lg:flex-row lg:items-center lg:justify-between">
      <div class="reveal max-w-2xl">
        <p class="eyebrow">Aan de slag</p>
        <h2 class="display h-section mt-4 text-white">Een plan, een verbouwing<br />of gewoon een vraag?</h2>
      </div>
      <div class="reveal flex flex-wrap items-center gap-3 lg:shrink-0">
        <a href="/contact" class="btn btn-geel">Offerte aanvragen</a>
        <a href={company.phoneHref} class="btn btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          {company.phone}
        </a>
      </div>
    </div>
  </div>
</section>
